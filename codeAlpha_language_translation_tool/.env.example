# ─── Lingua — Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# The app works out-of-the-box with MyMemory (free, no key required).

# ── MyMemory (default backend — free, no signup) ──────────────────────────────
# Adding your email raises the daily limit from ~5 000 → ~50 000 chars/day
MYMEMORY_EMAIL=

# ── Microsoft Azure Translator (overrides MyMemory when set) ──────────────────
# Get a key at: https://portal.azure.com → Cognitive Services → Translator
TRANSLATOR_API_KEY=
TRANSLATOR_REGION=eastus

# ── DeepL (overrides MyMemory when set) ───────────────────────────────────────
# Free API keys end in :fx  →  https://www.deepl.com/pro-api
DEEPL_API_KEY=

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
SECRET_KEY=change-me-to-something-random
